@model List<Bai6_Validation.Models.Book>

<h2>DANH SÁCH SÁCH</h2>

<a asp-action="Create">
    Thêm sách mới
</a>

<br />
<br />

<table border="1" cellpadding="10">

    <tr>
        <th>ID</th>
        <th>Tên sách</th>
        <th>Giá</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.Name</td>
            <td>@item.Price</td>
        </tr>
    }

</table>